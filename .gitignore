# Ephemeral raw harvests — evicted by capacity policy, never versioned.
# Pattern is data/* (not data/) so a parent-dir exclusion does not block the re-include
# below — git cannot re-include a file whose parent directory is excluded outright.
data/*
# EXCEPTION: static INE reference gazetteers the resolver reads at runtime
# (Nomenclátor de núcleos, INE dictionaries) — versioned reference data, not harvests.
!data/geo/

# Secrets
.env
.env.*
!.env.example

# Volatile state (capacity ledger, run state)
state/

# Runtime noise
*.log
__pycache__/
*.pyc
.venv/
node_modules/
.pytest_cache/
.backups/
scratch/
scripts/_*.py
scratch_*.py
.runlogs/
