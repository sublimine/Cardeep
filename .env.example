# Cardeep environment — copy to .env and fill. NEVER commit .env.

# PostgreSQL backbone (dev default; container cardeep-pg on port 5433)
CARDEEP_DSN=postgres://cardeep:cardeep_dev_only@localhost:5433/cardeep

# Local LLM for the cheap/massive layer (classify, parse, dedup)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Paid escalation (gated by owner — leave empty until authorized)
# DECODO_PROXY=
# CAPSOLVER_KEY=
